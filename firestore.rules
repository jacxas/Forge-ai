rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email in ['jacxas@gmail.com', 'jacxas@gmai.com']) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- Validation Blueprints ---
    
    function isValidAdmin(data) {
      return data.email is string && data.email.size() <= 256;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 512));
    }

    function isValidBot(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.description is string && data.description.size() <= 500
        && data.systemInstruction is string && data.systemInstruction.size() <= 5000
        && data.model is string
        && data.ownerId == request.auth.uid
        && data.avatarColor is string
        && data.icon is string;
    }

    function isValidMessage(data) {
      return data.id is string && data.id.size() <= 128
        && data.role in ['user', 'model']
        && data.content is string && data.content.size() <= 100000
        && data.timestamp is number
        && data.botId is string
        && (!('imageUrl' in data) || data.imageUrl is string)
        && (!('isImage' in data) || data.isImage is bool)
        && (!('attachedImage' in data) || (data.attachedImage is map && data.attachedImage.data is string));
    }

    // --- Collections ---

    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId) || isAdmin();

      match /bots/{botId} {
        allow list: if isOwner(userId) || isAdmin();
        allow get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(botId) && isValidBot(incoming());
        allow update: if (isOwner(userId) && isValidBot(incoming()) && incoming().ownerId == existing().ownerId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /sessions/{botId}/messages/{messageId} {
        allow list: if isOwner(userId) || isAdmin();
        allow get: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) && isValidId(messageId) && isValidMessage(incoming())) || isAdmin();
        allow update: if isAdmin(); // Messages are immutable for users, but admins can correct
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /admins/{adminId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin() && isValidAdmin(incoming());
      allow update: if isAdmin() && isValidAdmin(incoming());
      allow delete: if isAdmin();
    }
  }
}
