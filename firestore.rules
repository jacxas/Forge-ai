rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == '7ckV2j2YwOOQgCa5Wa1hUlYZRnH2' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'jacxas@gmail.com') ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'jacxas@gmai.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email == request.auth.token.email
        && data.displayName is string && data.displayName.size() <= 100
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
        && data.updatedAt is number
        && (!data.keys().hasAll(['isAdmin']) || isAdmin());
    }

    function isValidBot(data) {
      return data.id is string && data.id.size() <= 100
        && data.name is string && data.name.size() <= 64
        && data.description is string && data.description.size() <= 600
        && data.systemInstruction is string && data.systemInstruction.size() <= 10000
        && data.model is string && data.model.size() <= 100
        && data.avatarColor is string && data.avatarColor.size() <= 50
        && data.icon is string && data.icon.size() <= 50
        && (data.avatarUrl == null || (data.avatarUrl is string && data.avatarUrl.size() <= 2000))
        && data.ownerId == request.auth.uid
        && data.createdAt is number;
    }

    function isValidMessage(data) {
      return data.id is string && data.id.size() <= 100
        && data.role in ['user', 'model']
        && (data.content is string && data.content.size() <= 50000)
        && data.timestamp is number
        && data.botId is string && data.botId.size() <= 100;
    }

    // --- Match Rules ---

    match /admins/{adminId} {
      allow read: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) 
        && isValidUser(incoming())
        && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt', 'settings']));
    }

    match /users/{userId}/bots/{botId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get: if (isOwner(userId) || isAdmin()) && isValidId(botId);
      allow create: if isOwner(userId) && isValidBot(incoming());
      allow update: if (isOwner(userId) || isAdmin()) 
        && isValidBot(incoming())
        && (isAdmin() || (incoming().ownerId == existing().ownerId && incoming().createdAt == existing().createdAt));
      allow delete: if (isOwner(userId) || isAdmin()) && isValidId(botId);
    }

    match /users/{userId}/sessions/{botId}/messages/{messageId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get: if (isOwner(userId) || isAdmin()) && isValidId(messageId);
      allow create: if isOwner(userId) && isValidMessage(incoming());
      allow update: if isAdmin(); // Users shouldn't typically update messages once sent
      allow delete: if (isOwner(userId) || isAdmin()) && isValidId(messageId);
    }
  }
}
